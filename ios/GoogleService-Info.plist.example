<?xml version="1.0" encoding="UTF-8"?>
<!--
  Replace with GoogleService-Info.plist from Firebase Console (iOS app).
  Copy to ios/LearningApp/GoogleService-Info.plist and add to the Xcode target.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CLIENT_ID</key>
  <string>REPLACE_ME</string>
  <key>REVERSED_CLIENT_ID</key>
  <string>REPLACE_ME</string>
  <key>API_KEY</key>
  <string>REPLACE_ME</string>
  <key>GCM_SENDER_ID</key>
  <string>000000000000</string>
  <key>PLIST_VERSION</key>
  <string>1</string>
  <key>BUNDLE_ID</key>
  <string>com.learningapp</string>
  <key>PROJECT_ID</key>
  <string>learning-app-example</string>
  <key>STORAGE_BUCKET</key>
  <string>learning-app-example.appspot.com</string>
  <key>IS_ADS_ENABLED</key>
  <false/>
  <key>IS_ANALYTICS_ENABLED</key>
  <false/>
  <key>IS_APPINVITE_ENABLED</key>
  <true/>
  <key>IS_GCM_ENABLED</key>
  <true/>
  <key>IS_SIGNIN_ENABLED</key>
  <true/>
  <key>GOOGLE_APP_ID</key>
  <string>1:000000000000:ios:0000000000000000000000</string>
</dict>
</plist>
