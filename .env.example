# Copy to `.env` / `.env.production` and set per flavor.
# Never commit secrets. AI keys belong on a backend proxy, not in this file.

APP_ENV=development
API_BASE_URL=https://api.example.com

# Set true only after google-services.json + GoogleService-Info.plist are added.
FIREBASE_ENABLED=false

# Kid-first MVP keeps auth optional until Parent Dashboard needs sync.
AUTH_REQUIRED=false

# Backend proxy endpoints (never embed OpenAI/Gemini/TTS secret keys in the app).
OPENAI_PROXY_URL=
GEMINI_PROXY_URL=
TTS_PROXY_URL=
# openai | gemini — used when both LLM proxies are configured
PREFERRED_AI_PROVIDER=openai
