# Copy to `.env` / `.env.production` and set per flavor.
# Never commit secrets. AI keys belong on a backend proxy, not in this file.

APP_ENV=development
API_BASE_URL=https://api.example.com

# Set true only after android/app/google-services.json is present.
FIREBASE_ENABLED=true

# Google Sign-In required before learning (no guest).
AUTH_REQUIRED=true

# Web OAuth client ID (client_type 3) — required by GoogleSignin.configure for Firebase idToken.
# Find it in google-services.json under oauth_client where client_type is 3.
GOOGLE_WEB_CLIENT_ID=

# Backend proxy endpoints (never embed OpenAI/Gemini/TTS secret keys in the app).
OPENAI_PROXY_URL=
GEMINI_PROXY_URL=
# Optional direct Gemini SDK (dev only — prefer proxy in production).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
TTS_PROXY_URL=
# gemini | openai — used when multiple LLM backends are configured
PREFERRED_AI_PROVIDER=gemini
